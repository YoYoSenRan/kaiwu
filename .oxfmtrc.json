{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 150,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "objectWrap": "collapse",
  "ignorePatterns": ["**/dist/**", "**/.next/**", "**/.turbo/**"]
}
