{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import"],
  "rules": {
    "no-console": "warn",
    "no-debugger": "error",
    "eqeqeq": "error",
    "typescript/no-explicit-any": "error",
    "unicorn/no-null": "off"
  },
  "ignorePatterns": [
    "node_modules",
    ".next",
    "dist",
    ".turbo"
  ]
}
