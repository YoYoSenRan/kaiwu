{
  "name": "kaiwu",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@kaiwu/console --filter=@kaiwu/site",
    "dev:console": "turbo run dev --filter=@kaiwu/console",
    "dev:site": "turbo run dev --filter=@kaiwu/site",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:type": "turbo run lint:type",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.8.17"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,mts}": [
      "oxlint",
      "oxfmt"
    ],
    "*.{json,yaml,yml,md,mdx,css,scss,html}": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@10.4.1"
}
